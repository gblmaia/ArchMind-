# ============================================
# ArchMind - .gitignore (Enterprise Style)
# ============================================

# Ambiente virtual
venv/
.env
.env.*

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# IDEs
.idea/
.vscode/
*.swp
*.swo
*~

# Banco de dados vetorial (NUNCA commitar)
chroma_db/
chroma_db

# Documentos e dados sensíveis
data/
*.pdf
*.docx
*.xlsx

# Logs e arquivos temporários
*.log
*.tmp
*.temp

# Sistema operacional
.DS_Store
Thumbs.db

# Testes e cobertura
.coverage
htmlcov/
.pytest_cache/